        description="Run the git command in the patch queue directory.",
    )
    parser_qgit.set_defaults(handler=command_qgit)

    # refresh
    parser_refresh = subparsers.add_parser(
        "refresh",
        help="update the current patch",
        description="Update the current patch.",
    )
    parser_refresh.add_argument(
        "-e", "--edit", action="store_true", help="invoke editor on commit messages"
    )
    parser_refresh.set_defaults(handler=command_refresh)

    # rename
    parser_rename = subparsers.add_parser(
        "rename",
        aliases=["mv"],
        help="rename a patch",
        description="Rename a patch. With one argument, renames the current patch to PATCH1. With two arguments, renames PATCH1 to PATCH2.",
    )
    parser_rename.add_argument("patch1", help="1st patch file name")
    parser_rename.add_argument("patch2", help="2nd patch file name", nargs="?")
    parser_rename.set_defaults(handler=command_rename)

    # repair
    parser_repair = subparsers.add_parser(
        "repair",
        help="fix stq metadata",
        description="Fix stq metadata and update the patch files based on the current StGit status. Also fix StGit metadata.",
    )
    parser_repair.add_argument(
        "-s", "--skip-stg", action="store_true", help="skip fixing StGit metadata"
    )
    parser_repair.add_argument(
        "-p", "--skip-patch", action="store_true", help="skip updating patch files"
    )
    parser_repair.set_defaults(handler=command_repair)

    # select
    parser_select = subparsers.add_parser(
        "select",
        help="set or print guarded patches to push",
        description="Set or print guarded patches to push.",
    )
    parser_select.add_argument(
        "-n", "--none", action="store_true", help="disable all guards"
    )
    parser_select.add_argument(
        "-s", "--series", action="store_true", help="list all guards in series file"
    )
    parser_select.add_argument(
        "--pop", action="store_true", help="pop to before first guarded applied patch"
    )
    parser_select.add_argument(
        "--reapply", action="store_true", help="pop, then reapply patches"
    )
    parser_select.add_argument(
        "guard",
        nargs="*",
        help="guard(s) to be selected",
    )
    parser_select.set_defaults(handler=command_select)

    # series
    parser_series = subparsers.add_parser(
        "series",
        help="print the entire series file",
        description="Print the entire series file.",
    )
    parser_series.set_defaults(handler=command_series)

    # version
    parser_version = subparsers.add_parser(
        "version",
        help="show the version",
        description="Show the version",
    )
    parser_version.set_defaults(handler=command_version)

    # help
    parser_help = subparsers.add_parser(
        "help", help="show the help of the specified subcommand"
    )
    parser_help.add_argument(
        "command", nargs="?", help="command name which help is shown"
    )
    parser_help.set_defaults(handler=command_help, parser=parser, subparsers=subparsers)

    # Common options
    parser.add_argument("-C", dest="path", type=Path, help="set current directory")
    parser.add_argument(
        "-v", "--verbose", action="store_true", help="enable additional output"
    )

    idx, cmd = search_subcommand()
    if idx < 0:
        parser.print_help()
        sys.exit(0)
    cmd = get_subcommand(parser, subparsers, cmd)
    sub_argv = sys.argv[idx + 1 :]
    args, argv = parser.parse_known_args(sys.argv[1:idx] + [cmd] + sub_argv)

    if args.path:
        os.chdir(args.path)

    if hasattr(args, "handler"):
        if args.handler in [command_edit, command_qgit]:
            return args.handler(args, argv)

        if argv:
            msg = "unrecognized arguments: %s"
            parser.error(msg % " ".join(argv))
        return args.handler(args)
    else:
        parser.print_help()


if __name__ == "__main__":
    main()
