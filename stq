    update_series_by_status(series_list, status_list)

    old_patch_list: list[StgSeriesItem] = []
    if args.merged:
        # Get current patch list before running "stg pull"
        old_patch_list = run_stg_series()

    # Run "stg pull"
    stgcmd = [conf.stg, "pull"]
    if args.nopush:
        stgcmd += ["--nopush"]
    if args.merged:
        stgcmd += ["--merged"]
    if args.repository:
        stgcmd += ["--", args.repository]
    res = subprocess.run(stgcmd)
    if res.returncode:
        sys.exit(res.returncode)

    # Update metadata
    for si in series_list:
        si.applied = "unapplied"
    patch_list = run_stg_series()
    update_series_by_stg_series(series_list, patch_list)

    if old_patch_list:
        # Remove merged patches
        remove_list: list[str] = []
        for o in old_patch_list:
            for p in patch_list:
                if o.patchname == p.patchname:
                    break
            else:
                remove_list += [o.patchname]
        series_list = [si for si in series_list if si.patchname not in remove_list]

    write_series(series, series_list)
    write_status_from_series(status, series_list)


def run_stg_rename(newpatch: str, oldpatch: Optional[str] = None) -> tuple[bool, str]:
    stgcmd = [conf.stg, "rename", "--"]
    if oldpatch is not None:
        stgcmd += [oldpatch]
    stgcmd += [newpatch]

    proc = subprocess.Popen(
        stgcmd,
        encoding="utf-8",
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
    )
    assert proc.stdout

    while True:
        line = proc.stdout.readline()
        if not line:
            if proc.poll() is not None:
                break
            continue
        print(line, end="")
        m = re.match(r'Renaming patch "[^"]*" to "(.*)" \.\.\. done', line)
        if m:
            return True, m.group(1)

    return False, ""


def run_stg_import(patchfile: Path, patchname: Optional[str]) -> tuple[bool, str]:
    proc = subprocess.Popen(
        [conf.stg, "import", "--keep-cr", "--reject", "--", str(patchfile)],
        encoding="utf-8",
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
    )
    assert proc.stdout

    if not patchname:
        patchname = patchfile.name

    apply_fail = False
    while True:
        line = proc.stdout.readline()
        if not line:
            if proc.poll() is not None:
                break
            continue
        print(line, end="")
        m = re.match(r'  Now at patch "(.*)"', line)
        if m:
            new_patchname = m.group(1)
            if patchname != new_patchname:
                # Try using patchname defined in series
                ok, new_patchname2 = run_stg_rename(patchname)
                if ok:
                    new_patchname = new_patchname2
            return True, new_patchname
        m = re.match(r"stg import: Patch does not apply cleanly", line)
        if m:
            apply_fail = True
            break

    if apply_fail:
        # Run "stg new" to prepare an empty patch
        message = patchfile.name  # TODO: Extract the message from the patch
        patchname = run_stg_new(patchfile.name, message)
        return False, patchname

    return False, ""


def run_stg_push_multi(
    patchname_list: list[str],
) -> tuple[bool, list[tuple[str, bool]]]:
    stgcmd = [conf.stg, "push", "--"] + patchname_list
    proc = subprocess.Popen(
        stgcmd,
        encoding="utf-8",
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
    )
    assert proc.stdout

    res: list[tuple[str, bool]] = []
    while True:
        line = proc.stdout.readline()
        if not line:
            if proc.poll() is not None:
                break
            continue
        print(line, end="")
        m = re.match(r'Pushing patch "(.*)" ... done *(\(unmodified\))?', line)
        if m:
            unmodified = True if m.group(2) else False
            res += [(m.group(1), unmodified)]

    if proc.returncode != 0:
        return False, res
    return True, res


def run_stg_push(patchname: str) -> tuple[str, bool]:
    ok, res = run_stg_push_multi([patchname])
    if not ok or len(res) == 0:
        return "", True
    return res[0]


def get_first_unapplied_patch(
    patch_list: list[tuple[bool, str]], start_idx: int = 0
) -> int:
    for i in range(start_idx, len(patch_list)):
        if not patch_list[i][0]:
            return i
    return -1


def push_patches(
    pushall: Optional[bool] = None,
    number: Optional[int] = None,
    move: Optional[bool] = None,
    patchname: Optional[str] = None,
):
    patdir = ensure_patchesdir()

    series = patdir / "series"
    series_list = read_series(series)
    status = patdir / "status"
    status_list = read_status(status)
    guards = patdir / "guards"
    guards_list = read_guards(guards)

    update_series_by_guards(series_list, guards_list)
    update_series_by_status(series_list, status_list)

    filtered_list = get_ungarded_patch_list(series_list)
    if not filtered_list:
        print("stq: Patch series already fully applied.", file=sys.stderr)
        sys.exit(1)

    if not pushall:
        idx = -1
        if patchname:
            idx = get_matching_patch(filtered_list, patchname)
            if idx < 0:
                print(f"stq: Patch not found: {patchname}", file=sys.stderr)
                sys.exit(1)

        if move:
            if idx < 0:
                print("stq: Patch not specified", file=sys.stderr)
                sys.exit(1)
            si = filtered_list[idx]
            filtered_list = [si]
            # Reorder series_list
            series_list.remove(si)
            i = get_last_applied_patch(series_list) + 1
            series_list.insert(i, si)
        else:
            if idx >= 0:
                number = idx + 1
            elif number is None:
                number = 1

            del filtered_list[number:]

    # Classify the patches:
    #  1. Not applied yet, already registered in stg series
    #  2. Not applied yet, not registered in stg series

    patch_list = run_stg_series("unapplied")

    if len(patch_list) > 0:
        # There are patches already in stg series
        patchname_list: list[str] = []
        new_patch_list: list[StgSeriesItem] = []
        new_filtered_list: list[SeriesItem] = []
        j = -1
        for i, si in enumerate(filtered_list):
            while True:
                j += 1
                if j >= len(patch_list):
                    new_filtered_list += [filtered_list[i]]
                    break
                if (
                    si.patchname == patch_list[j].patchname
                    or si.patchfile == patch_list[j].patchname
                ):
                    patchname_list += [patch_list[j].patchname]
                    break
                else:
                    new_patch_list += [patch_list[j]]
        patch_list = new_patch_list

        ok, ret = run_stg_push_multi(patchname_list)

        for si, r in zip(filtered_list, ret):
            patchname, unmodified = r
            if not si.commitid or not unmodified:
                si.commitid = ""  # get_stg_commitid(patchname)
            status_list += [StatusItem(si.commitid, patchname)]
        if not ok:
            write_series(series, series_list)
            write_status(status, status_list)
            sys.exit(1)

        filtered_list = new_filtered_list

    # Push remaining patches
    for si in filtered_list:
        print(si.patchfile)
        patchname = ""
        for p in patch_list:
            if si.patchname == p.patchname or si.patchfile == p.patchname:
                patchname = p.patchname
                break
        if patchname:
            # Already registered
            si.patchname, unmodified = run_stg_push(patchname)
            if si.patchname:
                apply_cleanly = True
            else:
                apply_cleanly = False
        else:
            # Not registered
            apply_cleanly, si.patchname = run_stg_import(
                patdir / si.patchfile, si.patchname
            )
            si.commitid = ""  # get_stg_commitid(si.patchname)
        status_list += [StatusItem(si.commitid, si.patchname)]  # ty: ignore[invalid-argument-type]

        if not apply_cleanly:
            write_series(series, series_list)
            write_status(status, status_list)
            sys.exit(1)

    write_series(series, series_list)
    write_status(status, status_list)


