def search_subcommand() -> tuple[int, str]:
    i = 0
    while i < len(sys.argv) - 1:
        i += 1
        arg = sys.argv[i]
        if arg.startswith("-"):
            if arg.startswith("-C="):
                continue
            if arg == "-C":
                i += 1
                continue
            if arg in ["-h", "--h", "--he", "--hel", "--help"]:
                return i, "help"
        else:
            return i, arg

    return -1, ""


def get_subcommand(
    parser: argparse.ArgumentParser, subparsers: argparse._SubParsersAction, cmd: str
) -> str:
    allcmds = subparsers._name_parser_map.keys()

    # Check exact match
    if cmd in allcmds:
        return cmd

    # Check abbreviated commands
    cmds = [x for x in allcmds if x.startswith(cmd)]

    if len(cmds) == 1:
        return cmds[0]
    else:
        if len(cmds) == 0:
            print(f'stq: Unknown subcommand: "{cmd}"', file=sys.stderr)
        else:
            print(
                f'stq: Ambiguous subcommand: "{cmd}" (candidates: {sorted(cmds)})',
                file=sys.stderr,
            )
        parser.print_usage(sys.stderr)
        sys.exit(1)


def enable_esc_seq():
    """Enable ANSI escape sequences

    This is useful on Windows 10 or later. Do nothing on other OSes.
    """
    if os.name != "nt":
        return

    from ctypes import byref, c_uint, windll

    STD_OUTPUT_HANDLE = c_uint(-11)
    ENABLE_VIRTUAL_TERMINAL_PROCESSING = 0x4

    out = windll.kernel32.GetStdHandle(STD_OUTPUT_HANDLE)
    mode = c_uint()
    windll.kernel32.GetConsoleMode(out, byref(mode))
    mode.value |= ENABLE_VIRTUAL_TERMINAL_PROCESSING
    windll.kernel32.SetConsoleMode(out, mode)


