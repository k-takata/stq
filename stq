# Color configurations
COL_APPLIED = COLOR_BOLD + COLOR_UNDERLINE + COLOR_BLUE
COL_UNAPPLIED = COLOR_BOLD + COLOR_GRAY
COL_UNGUARDED = COLOR_GREEN
COL_POS_GUARD = COLOR_YELLOW
COL_NEG_GUARD = COLOR_RED
COL_OFF = COLOR_RESET


class Configurations:
    def __init__(self):
        self.stg = "stg"
        self.git = "git"


conf = Configurations()


def does_search_across_fs() -> bool:
    val = os.getenv("GIT_DISCOVERY_ACROSS_FILESYSTEM", "")
    return val == "1" or val.lower() == "true"


def get_git_topdir(path: Optional[Path] = None) -> Optional[Path]:
    """Get the git toplevel directory.
    Same as `git rev-parse --show-toplevel`.
    """
    if not path:
        path = Path.cwd()
    path = path.resolve()
    while True:
        if (path / ".git").exists():
            return path
        parent = path.parent
        if parent.is_mount() and not does_search_across_fs():
            # Filesystem boundary
            return None
        if parent == path:
            # Root directory.
            return None
        # TODO: Check GIT_CEILING_DIRECTORIES
        path = parent


def get_gitdir(path: Optional[Path] = None) -> Optional[Path]:
    """Get the git directory. (E.g. ".git")
    Same as `git rev-parse --git-dir` except that this returns an absolute path.
    """
    gittop = get_git_topdir(path)
    if not gittop:
        return None
    gitdir = gittop / ".git"
    if gitdir.is_dir():
        return gitdir
    if gitdir.is_file():
        with gitdir.open() as f:
            s = f.readline()
            m = re.match(r"gitdir: (.+)$", s)
            if m:
                gitdir = gittop / m.group(1)
                if gitdir.is_dir():
                    return gitdir
    return None


def get_patchesdir(path: Optional[Path] = None) -> Optional[Path]:
    """Get the patches directory. (E.g. ".git/patches")"""
    git_dir = get_gitdir(path)
    if not git_dir:
        return None
    return git_dir / "patches"


def ensure_patchesdir(path: Optional[Path] = None, create: bool = False) -> Path:
    patdir = get_patchesdir(path)
    if not patdir:
        print("stq: .git directory not found.", file=sys.stderr)
        sys.exit(1)
    if not patdir.exists():
        if create:
            patdir.mkdir(exist_ok=True)
        else:
            print("stq: Please run 'stq init' first.", file=sys.stderr)
            sys.exit(1)
    return patdir


def read_guards(guards: Path) -> list[str]:
    guards_list: list[str] = []

    if not guards.exists():
        return guards_list

    with guards.open() as f:
        for s in f.readlines():
            guards_list += [s.strip()]

    return guards_list


def write_guards(guards: Path, guards_list: list[str]) -> None:
    with guards.open("w") as f:
        for s in guards_list:
            print(s, file=f)


class SeriesItem:
    def __init__(
        self,
        patchfile: str,
        patchname: str,
        positive_guards: list[str],
        negative_guards: list[str],
        applied: Optional[str] = None,  # None, "applied", "unapplied"
        guarded: Optional[str] = None,  # None, "guarded", "unguarded"
        commitid: Optional[str] = None,
    ):
        assert applied in [None, "applied", "unapplied"]
        assert guarded in [None, "guarded", "unguarded"]

        self.patchfile = patchfile
        self.patchname = patchname
        self.positive_guards = positive_guards
        self.negative_guards = negative_guards
        self.applied = applied
        self.guarded = guarded
        self.commitid = commitid


class StgSeriesItem:
    def __init__(
        self,
        patchname: str,
        applied: bool,
    ):
        self.patchname = patchname
        self.applied = applied


class StatusItem:
    def __init__(self, commitid: str, patchname: str):
        self.commitid = commitid
        self.patchname = patchname


def read_series(series: Path) -> list[SeriesItem]:
    series_list: list[SeriesItem] = []

    if not series.exists():
        return series_list

    with series.open() as f:
        for s in f.readlines():
            patchfile, *items = s.split()

            if patchfile.startswith("#"):
                # Skip comment
                continue

            patchname = patchfile
            positive_guards: list[str] = []
            negative_guards: list[str] = []

            for i in items:
                t = i[:2]
                name = i[2:]

                if t == "#=":
                    patchname = name
                elif t == "#+":
                    positive_guards += [name]
                elif t == "#-":
                    negative_guards += [name]
                else:
                    # Ignore other (special) comments
                    pass

            series_list += [
                SeriesItem(patchfile, patchname, positive_guards, negative_guards)
            ]

    return series_list


def write_series(series: Path, series_list: list[SeriesItem]) -> None:
    with series.open("w") as f:
        for si in series_list:
            s = si.patchfile
            if si.patchname and si.patchname != si.patchfile:
                s += f" #={si.patchname}"
            if si.positive_guards:
                for i in si.positive_guards:
                    s += f" #+{i}"
            if si.negative_guards:
                for i in si.negative_guards:
                    s += f" #-{i}"
            print(s, file=f)


def update_series(
    series_list: list[SeriesItem], patchname: str, insert_idx: int, applied: bool
) -> tuple[str, bool]:
    # Search patchname from series_list
    for si in series_list:
        if si.patchname == patchname or si.patchfile == patchname:
            if applied:
                si.commitid = ""  # get_stg_commitid(patchname)
                si.applied = "applied"
            else:
                si.applied = "unapplied"
            return si.patchfile, False

    # Not found, add to series_list
    if insert_idx == -1:
        insert_idx = len(series_list)
    if applied:
        applied_str = "applied"
        commitid = ""  # get_stg_commitid(patchname)
    else:
        applied_str = "unapplied"
        commitid = None
    series_list.insert(
        insert_idx,
        SeriesItem(patchname, "", [], [], applied_str, "unguarded", commitid),
    )
    return patchname, True


def update_series_by_guards(
    series_list: list[SeriesItem], guards_list: list[str]
) -> None:
    for si in series_list:
        if si.positive_guards:
            guarded = "guarded"
        else:
            guarded = "unguarded"

        for pg in si.positive_guards:
            if pg in guards_list:
                guarded = "unguarded"
        for ng in si.negative_guards:
            if ng in guards_list:
                guarded = "guarded"

        si.guarded = guarded


def update_series_by_status(
    series_list: list[SeriesItem], status_list: list[StatusItem]
) -> None:
    for si in series_list:
        if si.patchname:
            patchname = si.patchname
        else:
            patchname = si.patchfile

        applied = "unapplied"
        for sti in status_list:
            if patchname == sti.patchname:
                applied = "applied"

        si.applied = applied


def update_series_by_stg_series(
    series_list: list[SeriesItem],
    patch_list: list[StgSeriesItem],
):
    idx = get_last_applied_patch(series_list) + 1
    for p in patch_list:
        _, added = update_series(series_list, p.patchname, idx, p.applied)
        if added:
            idx += 1


def get_matching_patch(series_list: list[SeriesItem], patch: str) -> int:
    for i, si in enumerate(series_list):
        if si.patchfile == patch or si.patchname == patch:
            return i
    return -1


def get_last_applied_patch(series_list: list[SeriesItem]) -> int:
    idx = -1
    for i, si in enumerate(series_list):
        if si.applied == "applied":
            idx = i
    return idx


def get_next_ungarded_patch(series_list: list[SeriesItem], start_idx: int = -1) -> int:
    if start_idx < 0:
        idx = get_last_applied_patch(series_list)
    else:
        idx = start_idx
    for i in range(idx + 1, len(series_list)):
        si = series_list[i]
        if si.guarded == "unguarded":
            return i
    return -1


def get_ungarded_patch_indexes(
    series_list: list[SeriesItem], start_idx: int = -1
) -> list[int]:
    idx_list: list[int] = []
    idx = start_idx
    while (idx := get_next_ungarded_patch(series_list, idx)) >= 0:
        idx_list += [idx]
    return idx_list


def get_ungarded_patch_list(
    series_list: list[SeriesItem], start_idx: int = -1
) -> list[SeriesItem]:
    idx_list = get_ungarded_patch_indexes(series_list, start_idx)
    return [series_list[i] for i in idx_list]


def get_stg_commitid(patchname: str) -> str:
    proc = subprocess.Popen(
        # Show only commit ID
        [
            conf.stg,
            "show",
            "--diff-opts=--no-patch",
            "--diff-opts=--format=%H",
            patchname,
        ],
        encoding="utf-8",
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
    )
    assert proc.stdout

    return proc.stdout.readline().rstrip()


def run_stg_series(status: str = "all") -> list[StgSeriesItem]:
    assert status in ["all", "applied", "unapplied"]

    stgcmd = [conf.stg, "series"]
    if status == "applied":
        stgcmd += ["--applied"]
    elif status == "unapplied":
        stgcmd += ["--unapplied"]

    proc = subprocess.Popen(
        stgcmd,
        encoding="utf-8",
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
    )
    assert proc.stdout

    patch_list: list[StgSeriesItem] = []
    while True:
        line = proc.stdout.readline()
        if not line:
            if proc.poll() is not None:
                break
            continue
        status, patch = line.rstrip().split(maxsplit=1)
        if status == "+" or status == ">":
            applied = True
        else:
            applied = False
        patch_list += [StgSeriesItem(patch, applied)]

    return patch_list


def read_status(status: Path) -> list[StatusItem]:
    status_list: list[StatusItem] = []

    if not status.exists():
        return status_list

    with status.open() as f:
        for s in f.readlines():
            if s:
                commitid, patchname = s.rstrip().split(":")
                status_list += [StatusItem(commitid, patchname)]

    return status_list


def write_status(status: Path, status_list: list[StatusItem]) -> None:
    with status.open("w") as f:
        for sti in status_list:
            print(f"{sti.commitid}:{sti.patchname}", file=f)


def write_status_from_series(status: Path, series_list: list[SeriesItem]) -> None:
    with status.open("w") as f:
        for si in series_list:
            if si.applied == "applied":
                patchname = si.patchname if si.patchname else si.patchfile
                print(f"{si.commitid}:{patchname}", file=f)


def command_delete(args: argparse.Namespace):
    patdir = ensure_patchesdir()

    series = patdir / "series"
    series_list = read_series(series)
    status = patdir / "status"
    status_list = read_status(status)
    guards = patdir / "guards"
    guards_list = read_guards(guards)

    update_series_by_guards(series_list, guards_list)
    update_series_by_status(series_list, status_list)

    remove_list: list[SeriesItem] = []
    for patch in args.patch:
        for si in series_list:
            if si.patchfile == patch or si.patchname == patch:
                # Patch found
                if si.applied == "applied":
                    print(
                        f'stq: Cannot delete applied patch: "{patch}"', file=sys.stderr
                    )
                    sys.exit(1)
                remove_list += [si]
                break
        else:
            print(f'stq: Patch not found: "{patch}"', file=sys.stderr)
            sys.exit(1)

    # Run "stg delete"
    patch_names = [si.patchname for si in remove_list]
    res = subprocess.run([conf.stg, "delete", "--"] + patch_names)
    if res.returncode:
        sys.exit(res.returncode)

    for si in remove_list:
        series_list.remove(si)
    write_series(series, series_list)


def command_discard(args: argparse.Namespace):
    _ = ensure_patchesdir()

    print("Popping all patches...")
    pop_patches(popall=True)

    patch_list = run_stg_series()
    if len(patch_list) == 0:
        print("stq: No patches registered in StGit.")
        return

    # Run "stg delete"
    patch_names = [p.patchname for p in patch_list]
    res = subprocess.run([conf.stg, "delete", "--"] + patch_names)
    if res.returncode:
        sys.exit(res.returncode)


def command_edit(args: argparse.Namespace, argv: list[str]):
    patdir = ensure_patchesdir()

    series = patdir / "series"
    series_list = read_series(series)
    status = patdir / "status"
    status_list = read_status(status)
    guards = patdir / "guards"
    guards_list = read_guards(guards)

    update_series_by_guards(series_list, guards_list)
    update_series_by_status(series_list, status_list)

    idx = get_last_applied_patch(series_list)
    if idx < 0:
        print("stq: no patches applied", file=sys.stderr)
        sys.exit(1)

    # Run "stg edit"
    stgcmd = [conf.stg, "edit"] + argv
    res = subprocess.run(stgcmd)
    if res.returncode:
        sys.exit(res.returncode)

    # Update the current patch file
    refresh_patch(patdir, series_list, idx)


def get_matching_patch_in_stg_series(
    patch_list: list[StgSeriesItem], patch: str
) -> int:
    for i, p in enumerate(patch_list):
        if p.patchname == patch:
            return i
    return -1


def command_fold(args: argparse.Namespace):
    patdir = ensure_patchesdir()

    series = patdir / "series"
    series_list = read_series(series)
    status = patdir / "status"
    status_list = read_status(status)
    guards = patdir / "guards"
    guards_list = read_guards(guards)

    update_series_by_guards(series_list, guards_list)
    update_series_by_status(series_list, status_list)

    idx = get_last_applied_patch(series_list)
    if idx < 0:
        print("stq: No patches applied", file=sys.stderr)
        sys.exit(1)

    patch_list = run_stg_series("unapplied")

    for patchname in args.patch:
        idx = get_matching_patch(series_list, patchname)
        if idx < 0:
            print(f"stq: Patch not found: {patchname}", file=sys.stderr)
            sys.exit(1)
        si = series_list[idx]
        patchpath = patdir / si.patchfile

        if get_matching_patch_in_stg_series(patch_list, si.patchname) >= 0:
            # Run "stg squash"
            res = subprocess.run([conf.stg, "squash", "--", si.patchname])
        else:
            # Run "git apply --index"
            res = subprocess.run([conf.git, "apply", "--index", str(patchpath)])
            if res.returncode:
                sys.exit(res.returncode)
            # Run "stg refresh"
            res = subprocess.run([conf.stg, "refresh"])

        if res.returncode:
            sys.exit(res.returncode)

        series_list.remove(si)
        if not args.keep:
            patchpath.unlink()

    write_series(series, series_list)

    # Update the current patch file
    refresh_patch(patdir, series_list, idx)


def show_guard_status(si: SeriesItem):
    if si.applied == "applied":
        print(f"{COL_APPLIED}{si.patchfile}{COL_OFF}:", end="")
    elif si.applied == "unapplied":
        print(f"{COL_UNAPPLIED}{si.patchfile}{COL_OFF}:", end="")
    else:
        print(f"{si.patchfile}:", end="")

    if si.positive_guards or si.negative_guards:
        for i in si.positive_guards:
            print(f" {COL_POS_GUARD}+{i}{COL_OFF}", end="")
        for i in si.negative_guards:
            print(f" {COL_NEG_GUARD}-{i}{COL_OFF}", end="")
    else:
        print(f" {COL_UNGUARDED}unguarded{COL_OFF}", end="")
    print()


def show_guard_list(series_list: list[SeriesItem]):
    for si in series_list:
        show_guard_status(si)


def command_guard(args: argparse.Namespace):
    patdir = ensure_patchesdir()

    series = patdir / "series"
    series_list = read_series(series)
    status = patdir / "status"
    status_list = read_status(status)
    guards = patdir / "guards"
    guards_list = read_guards(guards)

    update_series_by_guards(series_list, guards_list)
    update_series_by_status(series_list, status_list)

    patch = args.patch
    guard = args.guard

    if args.list:
        # Show guards list
        show_guard_list(series_list)
        return

    if patch is not None:
        if len(patch) > 0 and (patch[0] == "+" or patch[0] == "-"):
            guard.insert(0, patch)
            patch = None

    if patch:
        idx = get_matching_patch(series_list, patch)
        if idx < 0:
            print(f"stq: No patch named {patch}", file=sys.stderr)
            sys.exit(1)
    else:
        idx = get_last_applied_patch(series_list)
        if idx < 0:
            print("stq: No patches applied", file=sys.stderr)
            sys.exit(1)

    si = series_list[idx]

    if not guard and not args.none:
        # Show guards of the patch
        show_guard_status(si)
        return

    # Update series
    positive_guards: list[str] = []
    negative_guards: list[str] = []
    for g in guard:
        if len(g) <= 1 or (g[0] != "+" and g[0] != "-"):
            print(
                f'stq: wrong guard name: {g}, must be prefixed by "+" or "-"',
                file=sys.stderr,
            )
        if g[0] == "+":
            positive_guards += [g[1:]]
        if g[0] == "-":
            negative_guards += [g[1:]]

    si.positive_guards = positive_guards
    si.negative_guards = negative_guards
    write_series(series, series_list)


def import_patches(patches: list[Path]) -> None:
    patdir = ensure_patchesdir()

    series = patdir / "series"
    series_list = read_series(series)
    status = patdir / "status"
    status_list = read_status(status)
    guards = patdir / "guards"
    guards_list = read_guards(guards)

    update_series_by_guards(series_list, guards_list)
    update_series_by_status(series_list, status_list)

    added_patches: list[SeriesItem] = []
    for patch in patches:
        print(f"stq: Importing {patch}")
        if get_matching_patch(series_list, patch.name) >= 0:
            print(f"stq: Same patch name already exists: {patch.name}", file=sys.stderr)
            sys.exit(1)
        shutil.copy(patch, patdir)
        added_patches += [SeriesItem(patch.name, "", [], [])]

    series_list += added_patches
    write_series(series, series_list)


def command_import(args: argparse.Namespace):
    import_patches(args.patch)


def command_mqimport(args: argparse.Namespace):
    patdir = ensure_patchesdir()

    if not args.mq_dir.is_dir():
        print(f"stq: Error: not a directory: {args.mq_dir}", file=sys.stderr)
        sys.exit(1)

    series = args.mq_dir / "series"
    if not series.is_file():
        print(f"stq: Error: series file not found in {args.mq_dir}", file=sys.stderr)
        sys.exit(1)

    if (patdir / "series").is_file():
        print(f"stq: Error: series file already exists in {patdir}", file=sys.stderr)
        sys.exit(1)

    series_list = read_series(series)
    for si in series_list:
        patch = args.mq_dir / si.patchfile
        print("Copying:", patch)
        shutil.copy(patch, patdir)

    print("Copying:", series)
    shutil.copy(series, patdir)

    guards = args.mq_dir / "guards"
    if guards.is_file():
        print("Copying:", guards)
        shutil.copy(guards, patdir)


def command_init(args: argparse.Namespace):
    # Create .git/patches directory
    patdir = ensure_patchesdir(create=True)

    # Run "stg init"
    res = subprocess.run([conf.stg, "init"])

    # Create .gitignore
    gitign = patdir / ".gitignore"
    if not gitign.exists():
        with gitign.open("w") as f:
            print("guards", file=f)
            print("status", file=f)

    sys.exit(res.returncode)


def run_stg_new(patchname: str, message: str = "") -> str:
    proc = subprocess.Popen(
        [conf.stg, "new", f"--message={message}", "--", patchname],
        encoding="utf-8",
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
    )
    assert proc.stdout

    new_patchname = ""
    while True:
        line = proc.stdout.readline()
        if not line:
            if proc.poll() is not None:
                break
            continue
        print(line, end="")
        m = re.match(r'Now at patch "(.*)"', line)
        if m:
            new_patchname = m.group(1)

    return new_patchname


def command_new(args: argparse.Namespace):
    patdir = ensure_patchesdir()

    series = patdir / "series"
    series_list = read_series(series)
    status = patdir / "status"
    status_list = read_status(status)
    guards = patdir / "guards"
    guards_list = read_guards(guards)

    update_series_by_guards(series_list, guards_list)
    update_series_by_status(series_list, status_list)

    if args.message:
        message = args.message
    else:
        message = args.name

    # Run "stg new"
    patchname = run_stg_new(args.name, message)
    if not patchname:
        sys.exit(1)

    commitid = ""  # get_stg_commitid(patchname)
    status_list += [StatusItem(commitid, patchname)]

    idx = get_last_applied_patch(series_list) + 1
    series_list.insert(
        idx,
        SeriesItem(args.name, patchname, [], [], "applied", "unguarded", commitid),
    )

    write_series(series, series_list)
    write_status(status, status_list)


def run_stg_pop(popall: bool = False, number: int = 0) -> int:
    stgcmd = [conf.stg, "pop"]
    if popall:
        stgcmd += ["--all"]
    elif number > 0:
        stgcmd += [f"--number={str(number)}"]

    res = subprocess.run(stgcmd)
    return res.returncode


def get_pop_number(series_list: list[SeriesItem], patchname: str) -> int:
    n = -1
    for si in series_list:
        if si.applied == "applied":
            if si.patchfile == patchname or si.patchname == patchname:
                n = 0
            else:
                n += 1
    return n


def pop_patches(
    popall: Optional[bool] = None,
    number: Optional[int] = None,
    patchname: Optional[str] = None,
):
    patdir = ensure_patchesdir()

    series = patdir / "series"
    series_list = read_series(series)
    status = patdir / "status"
    status_list = read_status(status)
    guards = patdir / "guards"
    guards_list = read_guards(guards)

    update_series_by_guards(series_list, guards_list)
    update_series_by_status(series_list, status_list)

    idx = get_last_applied_patch(series_list)
    if idx < 0:
        print("stq: No patches applied", file=sys.stderr)
        sys.exit(1)

    if patchname:
        number = get_pop_number(series_list, patchname)
        if number < 0:
            print(f"stq: Patch not found: {patchname}", file=sys.stderr)
            sys.exit(1)

    if number is None:
        number = 1
    if popall is None:
